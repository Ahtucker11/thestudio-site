---
import PageLayout from "../layouts/PageLayout.astro";
import Container from "../components/layout/Container.astro";
import SectionLabel from "../components/ui/SectionLabel.astro";
import FadeIn from "../components/ui/FadeIn.astro";
import ServiceCards from "../components/sections/ServiceCards.astro";
import CTA from "../components/sections/CTA.astro";
---

<PageLayout
  title="Services"
  description="Explore our full range of services and find the right solution for your needs."
  canonicalPath="/services"
>
  <section class="section-light py-20 md:py-28">
    <Container>
      <FadeIn>
        <SectionLabel>Services</SectionLabel>
        <h1 class="mt-4 font-display font-bold text-brand" style="font-size: var(--text-4xl)">
          What We Offer
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-text-soft">
          Overview of your services and the value you provide.
        </p>
      </FadeIn>
    </Container>
  </section>

  <ServiceCards />

  <CTA
    heading="Ready to Start a Project?"
    body="Let's talk about what you need."
    primaryCta={{ label: "Contact Us", href: "/contact" }}
  />
</PageLayout>
