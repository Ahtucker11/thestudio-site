---
import PageLayout from "../layouts/PageLayout.astro";
import Container from "../components/layout/Container.astro";
import SectionLabel from "../components/ui/SectionLabel.astro";
import FadeIn from "../components/ui/FadeIn.astro";
import CTA from "../components/sections/CTA.astro";
import { getEntry } from "astro:content";

const teamData = await getEntry("team", "team");
const members = teamData?.data.members ?? [];
---

<PageLayout
  title="About"
  description="Learn about our team, our story, and what drives us."
  canonicalPath="/about"
>
  <section class="section-light py-20 md:py-28">
    <Container>
      <FadeIn>
        <SectionLabel>About Us</SectionLabel>
        <h1 class="mt-4 font-display font-bold text-brand" style="font-size: var(--text-4xl)">
          Our Story
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-text-soft">
          Tell your story here. What drives you, how you got started, and what makes you different.
        </p>
      </FadeIn>
    </Container>
  </section>

  {members.length > 0 && (
    <section class="section-warm py-20 md:py-24">
      <Container>
        <FadeIn>
          <SectionLabel>Team</SectionLabel>
          <h2 class="mt-4 font-display text-3xl font-bold text-brand" style="font-size: var(--text-3xl)">
            Meet the Team
          </h2>
        </FadeIn>

        <div class="mt-12 grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
          {members.map((member, i) => (
            <FadeIn delay={i * 100}>
              <div class="paper-card p-6">
                <h3 class="font-display text-xl font-bold text-sh-text">{member.name}</h3>
                <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.2em] text-accent">
                  {member.role}
                </p>
                <p class="mt-3 text-sm leading-relaxed text-text-soft">{member.bio}</p>
              </div>
            </FadeIn>
          ))}
        </div>
      </Container>
    </section>
  )}

  <CTA
    heading="Want to Work Together?"
    body="We'd love to hear about your project."
    primaryCta={{ label: "Get in Touch", href: "/contact" }}
  />
</PageLayout>
