---
import { cn } from "../../lib/utils";

interface Props {
  variant?: "primary" | "secondary" | "ghost" | "accent" | "primary-inv" | "ghost-inv" | "text-link";
  size?: "sm" | "md" | "lg";
  href?: string;
  class?: string;
  [key: string]: unknown;
}

const { variant = "primary", size = "md", href, class: className, ...rest } = Astro.props;

const variantClass = {
  primary: "btn-primary",
  secondary: "btn-secondary",
  ghost: "btn-ghost",
  accent: "btn-accent",
  "primary-inv": "btn-primary-inv",
  "ghost-inv": "btn-ghost-inv",
  "text-link": "btn-text-link",
}[variant];

const sizeClass = variant === "text-link" ? "" : `btn-${size}`;
const classes = cn("btn", sizeClass, variantClass, className);
const Tag = href ? "a" : "button";
---

{href ? (
  <a href={href} class={classes} {...rest}>
    <slot />
  </a>
) : (
  <button class={classes} {...rest}>
    <slot />
  </button>
)}
