---
interface Props {
  value: string;
  label: string;
  description?: string;
  dark?: boolean;
}

const { value, label, description, dark = false } = Astro.props;
---

<div class={dark ? "stat-dark" : ""}>
  <span class="stat-num">{value}</span>
  <span class="stat-label">{label}</span>
  {description && <p class="stat-desc">{description}</p>}
</div>
