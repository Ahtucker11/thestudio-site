---
---
<section id="top" class="hero">
  <div class="hero-photo" aria-hidden="true">
    <img
      src="/images/exterior.jpg"
      alt=""
      loading="eager"
      decoding="async"
      width="1600"
      height="1200"
    />
  </div>
  <div class="hero-scrim" aria-hidden="true"></div>

  <div class="hero-content">
    <h1 class="hero-mark" aria-label="The Studio — Walnut Hills">
      <span class="hero-mark-the" aria-hidden="true">THE</span>
      <span class="hero-mark-studio" aria-hidden="true">Studio</span>
      <span class="hero-mark-rule" aria-hidden="true"></span>
      <span class="hero-mark-tagline" aria-hidden="true">Walnut Hills</span>
    </h1>

    <p class="hero-tagline">A small creative studio in Walnut Hills, Cincinnati.</p>

    <a href="#about" class="hero-cta">About the space <span aria-hidden="true">→</span></a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    min-height: min(100vh, 760px);
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding: calc(var(--nav-height) + 48px) clamp(24px, 6vw, 80px) clamp(72px, 10vh, 120px);
    color: var(--text-inv);
    overflow: hidden;
  }

  .hero-photo {
    position: absolute;
    inset: 0;
    z-index: -2;
  }
  .hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 45%;
    display: block;
  }

  .hero-scrim {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(100deg, rgba(17,17,17,0.70) 0%, rgba(17,17,17,0.55) 45%, rgba(17,17,17,0.32) 100%),
      linear-gradient(180deg, rgba(17,17,17,0.25) 0%, rgba(17,17,17,0.0) 30%, rgba(17,17,17,0.25) 100%);
  }

  .hero-content {
    position: relative;
    max-width: 620px;
    width: 100%;
  }

  .hero-mark {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
    margin: 0;
    line-height: 1;
    font-weight: 400;
  }

  .hero-mark-the {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--text-inv-soft);
    padding-left: 0.25em;
    margin-bottom: 12px;
  }

  .hero-mark-studio {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(72px, 11vw, 136px);
    line-height: 0.92;
    letter-spacing: -0.02em;
    color: var(--text-inv);
    margin: 0;
  }

  .hero-mark-rule {
    display: block;
    width: 40px;
    height: 2px;
    background: var(--clay);
    margin: 22px 0 14px 6px;
  }

  .hero-mark-tagline {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--text-inv-soft);
    padding-left: 6px;
  }

  .hero-tagline {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(19px, 2.1vw, 25px);
    line-height: 1.4;
    color: var(--text-inv-soft);
    margin: 44px 0 0;
    max-width: 36ch;
    text-wrap: pretty;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: 40px;
    padding: 12px 22px;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-inv);
    background: var(--clay);
    text-decoration: none;
    transition: background var(--dur-fast) var(--ease-out);
  }

  .hero-cta:hover {
    background: var(--clay-dark);
  }

  @media (max-width: 640px) {
    .hero {
      min-height: 82vh;
      padding: calc(var(--nav-height) + 32px) 24px 64px;
    }
    .hero-mark-studio {
      font-size: clamp(64px, 18vw, 96px);
    }
  }
</style>
