---
<section class="hero">
  <div class="idx-column">
    <div class="idx-column-inner">
      <p class="meta-line">705 E. McMillan St · Unit 1 · 45206</p>

      <h1 class="hero-mark">
        The Studio<span class="hero-mark-stop" aria-hidden="true">.</span>
      </h1>

      <p class="hero-descriptor">A small creative studio in Walnut Hills, Cincinnati.</p>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 140px 0 0;
  }

  .hero .meta-line {
    margin-bottom: 88px;
  }

  .hero-mark {
    font-family: var(--font-display);
    font-weight: 400;
    font-variation-settings: "opsz" 144;
    font-size: clamp(64px, 9vw, 92px);
    line-height: 0.98;
    letter-spacing: -0.025em;
    color: var(--text);
    margin: 0;
  }

  .hero-mark-stop {
    color: var(--brand-accent);
  }

  .hero-descriptor {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 320;
    font-size: clamp(20px, 2.2vw, 25px);
    line-height: 1.45;
    color: var(--text-soft);
    margin: 32px 0 0;
    text-wrap: pretty;
    max-width: 28ch;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 96px 0 0;
    }
    .hero .meta-line {
      margin-bottom: 56px;
    }
  }
</style>
