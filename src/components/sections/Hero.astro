---
import Container from "../layout/Container.astro";
import Button from "../ui/Button.astro";
import SectionLabel from "../ui/SectionLabel.astro";
import FieldNote from "../ui/FieldNote.astro";
import FadeIn from "../ui/FadeIn.astro";

interface Props {
  eyebrow?: string;
  heading: string;
  subheading?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  fieldNote?: string;
}

const { eyebrow, heading, subheading, primaryCta, secondaryCta, fieldNote } = Astro.props;
---

<section class="section-light py-24 md:py-32 lg:py-40">
  <Container>
    <div class="max-w-3xl">
      {eyebrow && (
        <FadeIn>
          <SectionLabel>{eyebrow}</SectionLabel>
        </FadeIn>
      )}

      <FadeIn delay={100}>
        <h1
          class="mt-4 font-display font-bold leading-[1.1] tracking-tight text-brand"
          style={`font-size: var(--text-5xl)`}
        >
          {heading}
        </h1>
      </FadeIn>

      {subheading && (
        <FadeIn delay={200}>
          <p class="mt-6 max-w-xl text-lg leading-relaxed text-text-soft">
            {subheading}
          </p>
        </FadeIn>
      )}

      {(primaryCta || secondaryCta) && (
        <FadeIn delay={300}>
          <div class="mt-8 flex flex-wrap items-center gap-4">
            {primaryCta && (
              <Button variant="primary" size="lg" href={primaryCta.href}>
                {primaryCta.label}
              </Button>
            )}
            {secondaryCta && (
              <Button variant="ghost" size="lg" href={secondaryCta.href}>
                {secondaryCta.label}
              </Button>
            )}
          </div>
        </FadeIn>
      )}

      {fieldNote && (
        <FadeIn delay={400}>
          <div class="mt-6">
            <FieldNote>{fieldNote}</FieldNote>
          </div>
        </FadeIn>
      )}
    </div>
  </Container>
</section>
