---
import Container from "../layout/Container.astro";
import Button from "../ui/Button.astro";
import FadeIn from "../ui/FadeIn.astro";

interface Props {
  heading: string;
  body?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
}

const { heading, body, primaryCta, secondaryCta } = Astro.props;
---

<section class="section-dark py-20 md:py-28">
  <Container>
    <div class="tex-content text-center">
      <!-- Pulse rings -->
      <div class="pointer-events-none absolute inset-0 flex items-center justify-center">
        <div class="motion-pulse-ring h-64 w-64 rounded-full border border-cream/5"></div>
        <div class="motion-pulse-ring-delayed absolute h-96 w-96 rounded-full border border-cream/3"></div>
      </div>

      <FadeIn>
        <h2
          class="relative z-10 mx-auto max-w-2xl font-display font-bold text-cream"
          style="font-size: var(--text-4xl)"
        >
          {heading}
        </h2>
      </FadeIn>

      {body && (
        <FadeIn delay={100}>
          <p class="relative z-10 mx-auto mt-4 max-w-xl text-cream/60">
            {body}
          </p>
        </FadeIn>
      )}

      {(primaryCta || secondaryCta) && (
        <FadeIn delay={200}>
          <div class="relative z-10 mt-8 flex flex-wrap items-center justify-center gap-4">
            {primaryCta && (
              <Button variant="primary-inv" size="lg" href={primaryCta.href}>
                {primaryCta.label}
              </Button>
            )}
            {secondaryCta && (
              <Button variant="ghost-inv" size="lg" href={secondaryCta.href}>
                {secondaryCta.label}
              </Button>
            )}
          </div>
        </FadeIn>
      )}
    </div>
  </Container>
</section>
