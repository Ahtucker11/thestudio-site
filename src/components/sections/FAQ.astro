---
import { getEntry } from "astro:content";
import Container from "../layout/Container.astro";
import SectionLabel from "../ui/SectionLabel.astro";
import Card from "../ui/Card.astro";
import JsonLd from "../seo/JsonLd.astro";
import FadeIn from "../ui/FadeIn.astro";
import { buildFaqJsonLd } from "../../lib/seo";

interface Props {
  eyebrow?: string;
  heading?: string;
}

const { eyebrow = "FAQ", heading = "Frequently Asked Questions" } = Astro.props;

const faqData = await getEntry("faqs", "general");
const items = faqData?.data.items ?? [];
---

{items.length > 0 && <JsonLd data={buildFaqJsonLd(items)} />}

<section class="section-warm py-20 md:py-24" id="faq">
  <Container>
    <FadeIn>
      <SectionLabel>{eyebrow}</SectionLabel>
      <h2 class="mt-4 font-display text-3xl font-bold text-brand" style="font-size: var(--text-3xl)">
        {heading}
      </h2>
    </FadeIn>

    <div class="mt-12 grid grid-cols-1 gap-4 md:grid-cols-2">
      {items.map((item, i) => (
        <FadeIn delay={i * 80}>
          <Card variant="accent" class="p-6 transition-transform hover:-translate-y-0.5">
            <h3 class="font-display text-lg font-bold text-sh-text">{item.question}</h3>
            <p class="mt-2 text-sm leading-relaxed text-text-soft">{item.answer}</p>
          </Card>
        </FadeIn>
      ))}
    </div>
  </Container>
</section>
