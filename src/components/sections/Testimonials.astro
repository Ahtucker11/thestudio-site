---
import { getEntry } from "astro:content";
import Container from "../layout/Container.astro";
import SectionLabel from "../ui/SectionLabel.astro";
import Card from "../ui/Card.astro";
import FadeIn from "../ui/FadeIn.astro";

interface Props {
  eyebrow?: string;
  heading?: string;
}

const { eyebrow = "Testimonials", heading = "What Our Clients Say" } = Astro.props;

const testimonialData = await getEntry("testimonials", "testimonials");
const items = testimonialData?.data.items ?? [];
---

<section class="section-light py-20 md:py-24">
  <Container>
    <FadeIn>
      <SectionLabel>{eyebrow}</SectionLabel>
      <h2 class="mt-4 font-display text-3xl font-bold text-brand" style="font-size: var(--text-3xl)">
        {heading}
      </h2>
    </FadeIn>

    <div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-3">
      {items.map((item, i) => (
        <FadeIn delay={i * 100}>
          <Card variant="paper" class="p-6">
            <blockquote class="text-sm italic leading-relaxed text-text-soft">
              "{item.quote}"
            </blockquote>
            <div class="mt-4 border-t border-border-soft pt-4">
              <p class="font-display text-sm font-bold text-sh-text">{item.name}</p>
              <p class="font-mono text-[10px] uppercase tracking-widest text-text-muted">
                {item.role}{item.company && `, ${item.company}`}
              </p>
            </div>
          </Card>
        </FadeIn>
      ))}
    </div>
  </Container>
</section>
