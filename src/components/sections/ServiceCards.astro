---
import { getCollection } from "astro:content";
import Container from "../layout/Container.astro";
import SectionLabel from "../ui/SectionLabel.astro";
import Card from "../ui/Card.astro";
import Button from "../ui/Button.astro";
import FadeIn from "../ui/FadeIn.astro";

interface Props {
  eyebrow?: string;
  heading?: string;
}

const { eyebrow = "Services", heading = "What We Offer" } = Astro.props;

const services = (await getCollection("services")).sort(
  (a, b) => a.data.sortOrder - b.data.sortOrder
);
---

<section class="section-light py-20 md:py-24" id="services">
  <Container>
    <FadeIn>
      <SectionLabel>{eyebrow}</SectionLabel>
      <h2 class="mt-4 font-display text-3xl font-bold text-brand" style="font-size: var(--text-3xl)">
        {heading}
      </h2>
    </FadeIn>

    <div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-2">
      {services.map((service, i) => (
        <FadeIn delay={i * 100}>
          <Card variant="accent" class="p-6 transition-transform hover:-translate-y-0.5">
            {service.data.icon && (
              <span class="mb-3 inline-block font-mono text-2xl font-bold text-accent">
                {service.data.icon}
              </span>
            )}
            <h3 class="font-display text-xl font-bold text-sh-text">{service.data.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-text-soft">{service.data.tagline}</p>
            {service.data.features && (
              <ul class="mt-3 space-y-1">
                {service.data.features.map((f) => (
                  <li class="flex items-start gap-2 text-sm text-text-soft">
                    <span class="mt-1 text-accent">&#x2022;</span>
                    {f}
                  </li>
                ))}
              </ul>
            )}
            <div class="mt-4">
              <Button variant="text-link" href={`/services/${service.id}`}>
                Learn more
              </Button>
            </div>
          </Card>
        </FadeIn>
      ))}
    </div>
  </Container>
</section>
