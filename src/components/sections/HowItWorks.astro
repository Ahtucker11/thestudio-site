---
import Container from "../layout/Container.astro";
import SectionLabel from "../ui/SectionLabel.astro";
import FadeIn from "../ui/FadeIn.astro";

interface Step {
  num: string;
  title: string;
  duration?: string;
  description: string;
}

interface Props {
  eyebrow?: string;
  heading?: string;
  steps: Step[];
}

const { eyebrow = "Process", heading = "How It Works", steps } = Astro.props;
---

<section class="section-light py-20 md:py-24">
  <Container>
    <FadeIn>
      <SectionLabel>{eyebrow}</SectionLabel>
      <h2 class="mt-4 font-display text-3xl font-bold text-brand" style="font-size: var(--text-3xl)">
        {heading}
      </h2>
    </FadeIn>

    <div class="mt-12 grid grid-cols-1 gap-8 md:grid-cols-3">
      {steps.map((step, i) => (
        <FadeIn delay={i * 150}>
          <div class="group">
            <div class="mb-4 flex items-center gap-3">
              <span class="flex h-10 w-10 items-center justify-center rounded-full border-2 border-brand text-sm font-bold text-brand transition-transform group-hover:scale-110">
                {step.num}
              </span>
              {step.duration && (
                <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.2em] text-text-muted">
                  {step.duration}
                </span>
              )}
            </div>
            <h3 class="font-display text-xl font-bold text-sh-text">{step.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-text-soft">{step.description}</p>
          </div>
        </FadeIn>
      ))}
    </div>
  </Container>
</section>
