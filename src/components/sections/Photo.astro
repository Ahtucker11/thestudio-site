---
<section class="photo-section">
  <div class="idx-column">
    <div class="idx-column-inner">
      <figure class="photo-frame">
        <img
          src="/images/exterior.jpg"
          alt="The Studio at 705 East McMillan Street — grey-green storefront with bay windows and red door."
          loading="lazy"
          decoding="async"
          width="1600"
          height="1200"
        />
      </figure>
    </div>
  </div>
</section>

<style>
  .photo-section {
    padding: 72px 0 0;
  }

  .photo-frame {
    margin: 0;
    width: 100%;
    height: 420px;
    overflow: hidden;
    border: 1px solid var(--border-soft);
  }

  .photo-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    display: block;
  }

  @media (max-width: 768px) {
    .photo-frame {
      height: 320px;
    }
  }
</style>
