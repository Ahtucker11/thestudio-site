---
import { site } from "../../lib/site";
const year = new Date().getFullYear();
---

<footer class="studio-footer">
  <div class="idx-column">
    <div class="idx-column-inner studio-footer-inner">
      <a href={`mailto:${site.email}`} class="studio-footer-email">{site.email}</a>
      <p class="studio-footer-copy">© {year} · The Studio at 705 East McMillan</p>
    </div>
  </div>
</footer>

<style>
  .studio-footer {
    margin-top: 96px;
  }

  .studio-footer-inner {
    padding-top: 28px;
    border-top: 1px solid var(--border-soft);
    padding-bottom: 72px;
  }

  .studio-footer-email {
    display: inline-block;
    font-family: var(--font-display);
    font-weight: 400;
    font-variation-settings: "opsz" 144;
    font-size: 17px;
    color: var(--text);
    text-decoration: none;
    border-bottom: 1px solid transparent;
  }

  .studio-footer-email:hover {
    border-bottom-color: var(--text-soft);
  }

  .studio-footer-copy {
    margin: 10px 0 0;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.1em;
    color: var(--text-faint);
  }
</style>
