---
<nav class="nav" aria-label="Primary">
  <div class="nav-inner">
    <a href="#top" class="nav-logo" aria-label="The Studio — Walnut Hills">
      <span class="nav-logo-name">The Studio</span>
      <span class="nav-logo-sep" aria-hidden="true">|</span>
      <span class="nav-logo-tagline">Walnut Hills</span>
    </a>

    <ul class="nav-links" role="list">
      <li><a href="#about" class="nav-link">About</a></li>
      <li><a href="#businesses" class="nav-link">Businesses</a></li>
      <li><a href="#location" class="nav-link">Location</a></li>
    </ul>
  </div>
</nav>

<style>
  .nav {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 10;
    height: var(--nav-height);
    padding: 0 clamp(20px, 4vw, 48px);
    display: flex;
    align-items: center;
  }

  .nav-inner {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .nav-logo {
    display: inline-flex;
    align-items: baseline;
    gap: 10px;
    color: var(--text-inv);
    text-decoration: none;
    line-height: 1;
  }

  .nav-logo-name {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 21px;
    letter-spacing: 0.01em;
  }

  .nav-logo-sep {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: 20px;
    color: var(--text-inv-soft);
  }

  .nav-logo-tagline {
    font-family: var(--font-body);
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--text-inv-soft);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: clamp(20px, 3vw, 40px);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .nav-link {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-inv-soft);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-out);
  }

  .nav-link:hover {
    color: var(--text-inv);
  }

  @media (max-width: 640px) {
    .nav-logo-tagline,
    .nav-logo-sep {
      display: none;
    }
    .nav-links {
      gap: 16px;
    }
    .nav-link {
      font-size: 10px;
      letter-spacing: 0.18em;
    }
  }
</style>
