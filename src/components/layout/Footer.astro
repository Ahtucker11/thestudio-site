---
import Container from "./Container.astro";
import { footerLinks } from "../../data/navigation";
import { site } from "../../lib/site";

const year = new Date().getFullYear();
---

<footer class="section-dark ghost-hex-section py-16">
  <Container>
    <div class="tex-content">
      <div class="flex flex-col items-center gap-8 md:flex-row md:justify-between">
        <div>
          <p class="font-display text-xl font-bold text-cream">{site.name}</p>
          {site.tagline && (
            <p class="mt-1 text-sm text-cream/50">{site.tagline}</p>
          )}
        </div>

        <div class="flex flex-wrap items-center justify-center gap-3">
          {footerLinks.map((link) => (
            <a href={link.href} class="footer-link">{link.label}</a>
          ))}
        </div>
      </div>

      <div class="mt-12 border-t border-cream/10 pt-6 text-center">
        <p class="font-mono text-[10px] uppercase tracking-widest text-cream/30">
          &copy; {year} {site.name}. All rights reserved.
        </p>
      </div>
    </div>
  </Container>
</footer>
